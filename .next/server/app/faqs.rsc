9:T12b3,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Who is Jowam Coffee Traders LTD?","acceptedAnswer":{"@type":"Answer","text":"Jowam Coffee Traders LTD is a Kenyan company specializing in sourcing, processing, and exporting premium green coffee beans directly from farmers, cooperatives, and estates across Kenya. We connect global buyers with authentic Kenyan coffee at its source."}},{"@type":"Question","name":"Why choose Kenyan coffee from Jowam Coffee Traders?","acceptedAnswer":{"@type":"Answer","text":"Kenyan coffee is globally recognized for its bright acidity, wine-like notes, and complex flavors. At Jowam Coffee Traders, we ensure traceability, direct farmer relationships, and consistent quality, making us a trusted partner for roasters and distributors worldwide."}},{"@type":"Question","name":"What types of Kenyan coffee do you export?","acceptedAnswer":{"@type":"Answer","text":"We export a wide range of green coffee beans including Kenya AA, AB, PB (peaberry), and specialty microlots. Each lot is carefully graded and sourced from top coffee-growing regions such as Nyeri, Kirinyaga, Embu, Murang'a, and Kisii."}},{"@type":"Question","name":"Do you offer single-origin Kenyan coffee?","acceptedAnswer":{"@type":"Answer","text":"Yes, Jowam Coffee Traders provides single-origin coffees sourced from distinct regions and estates across Kenya, allowing roasters to experience the unique flavor profiles that each terroir offers."}},{"@type":"Question","name":"Where do you source your Kenyan coffee?","acceptedAnswer":{"@type":"Answer","text":"We source coffee directly from smallholder farmers, farmer cooperatives, and private estates in regions such as Nyeri, Kirinyaga, Bungoma, Murang'a, Meru, and Kisii, ensuring transparency and sustainability in every lot we export."}},{"@type":"Question","name":"How can I buy green coffee from Jowam Coffee Traders?","acceptedAnswer":{"@type":"Answer","text":"You can contact us directly via our website inquiry form or email. Once we receive your request, we will provide a catalog of available lots, samples if required, and assist with the ordering process for international buyers."}},{"@type":"Question","name":"Do you provide coffee samples before purchase?","acceptedAnswer":{"@type":"Answer","text":"Yes, we provide green coffee samples upon request so that buyers and roasters can cup and evaluate the quality before making bulk orders."}},{"@type":"Question","name":"Do you ship Kenyan coffee internationally?","acceptedAnswer":{"@type":"Answer","text":"Yes, we export worldwide through Mombasa Port using both sea and air freight options. We work with trusted logistics partners to ensure safe and timely delivery of green coffee to roasters and importers globally."}},{"@type":"Question","name":"What is the minimum order quantity for export?","acceptedAnswer":{"@type":"Answer","text":"Our standard minimum order is one full bag (60kg), though larger commercial buyers typically order multiple bags or full container loads. We can also accommodate microlot shipments for specialty roasters."}},{"@type":"Question","name":"How do you ensure the quality of your Kenyan coffee?","acceptedAnswer":{"@type":"Answer","text":"We work with certified cupping labs, licensed graders, and experienced Q-graders to evaluate every lot. Our coffee is carefully processed, sorted, and graded according to Kenya's Coffee Board standards before export."}},{"@type":"Question","name":"Is Jowam Coffee Traders committed to sustainable sourcing?","acceptedAnswer":{"@type":"Answer","text":"Yes, we are committed to ethical and sustainable sourcing. We prioritize partnerships with smallholder farmers and cooperatives that promote fair compensation, environmentally friendly practices, and community development."}},{"@type":"Question","name":"What payment methods do you accept for coffee orders?","acceptedAnswer":{"@type":"Answer","text":"We accept international wire transfers and letters of credit (LC). Payment terms depend on the order size and buyer relationship, and are always agreed upon before shipment."}},{"@type":"Question","name":"Do you work with international distributors and roasters?","acceptedAnswer":{"@type":"Answer","text":"Yes, Jowam Coffee Traders partners with coffee roasters, importers, and distributors worldwide. We provide tailored sourcing solutions, whether for large-scale commercial buyers or small specialty roasters."}},{"@type":"Question","name":"How can I get in touch with Jowam Coffee Traders?","acceptedAnswer":{"@type":"Answer","text":"You can reach us through our website contact form, by email at trading@jowamcoffee.com, or by phone. Our team is available to answer questions, provide samples, and guide you through the export process."}}]}0:{"P":null,"b":"nUueegzLDp8s1GVlalVzg","p":"","c":["","faqs"],"i":false,"f":[[["",{"children":["faqs",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/d6542b95d19a1b98.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","children":[["$","head",null,{"children":["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Jowam Coffee Traders LTD\",\"description\":\"Licensed Kenyan green coffee exporters specializing in premium arabica coffee for specialty roasters worldwide\",\"url\":\"https://jowamcoffee.co.ke\",\"logo\":\"https://jowamcoffee.co.ke/logo.png\",\"contactPoint\":{\"@type\":\"ContactPoint\",\"telephone\":\"+254-123-456-789\",\"contactType\":\"sales\",\"email\":\"info@jowamcoffee.co.ke\",\"availableLanguage\":\"English\"},\"address\":{\"@type\":\"PostalAddress\",\"addressCountry\":\"KE\",\"addressLocality\":\"Nairobi\"},\"sameAs\":[\"https://linkedin.com/company/jowam-coffee-traders\",\"https://facebook.com/jowamcoffee\"]}"}}]}],["$","body",null,{"children":[["$","$L2",null,{"children":["$","div",null,{"className":"min-h-screen flex flex-col","children":[["$","$L3",null,{}],["$","main",null,{"className":"flex-1","children":["$","$L4",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","$L6",null,{}],[]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","$L7",null,{}]]}]}],["$","$L8",null,{"src":"https://umami.mawirab.com/script.js","data-website-id":"c4d120e7-565d-43bf-8d1d-a7b7dfb1acc5","strategy":"afterInteractive"}]]}]]}]]}],{"children":["faqs",["$","$1","c",{"children":[null,["$","$L4",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$9"}}],"$La","$Lb","$Lc"],null,"$Ld"]}],{},null,false]},null,false]},null,false],"$Le",false]],"m":"$undefined","G":["$f",[]],"s":false,"S":true}
