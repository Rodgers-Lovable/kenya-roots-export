{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/articles/[id]/edit",
      "regex": "^/admin/articles/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/articles/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
    {
      "page": "/insights/[slug]",
      "regex": "^/insights/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/insights/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/origins/[slug]",
      "regex": "^/origins/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/origins/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/articles",
      "regex": "^/admin/articles(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/articles(?:/)?$"
    },
    {
      "page": "/admin/articles/new",
      "regex": "^/admin/articles/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/articles/new(?:/)?$"
    },
    {
      "page": "/admin/auth",
      "regex": "^/admin/auth(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/auth(?:/)?$"
    },
    {
      "page": "/catalog",
      "regex": "^/catalog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/catalog(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/faqs",
      "regex": "^/faqs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faqs(?:/)?$"
    },
    {
      "page": "/insights",
      "regex": "^/insights(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/insights(?:/)?$"
    },
    {
      "page": "/origins",
      "regex": "^/origins(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/origins(?:/)?$"
    },
    {
      "page": "/our-coffee",
      "regex": "^/our\\-coffee(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/our\\-coffee(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/process",
      "regex": "^/process(?:/)?$",
